rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public wheel can read/write quota state.
    match /meta/{docId} {
      allow read, write: if true;
    }

    match /rounds/{roundId} {
      allow read, write: if true;
    }

    // Public wheel reservations/confirmation are allowed without auth.
    // Admin can read all to show stats/export.
    match /responses/{responseId} {
      allow create: if
        request.resource.data.status == 'pending'
        && request.resource.data.deviceId is string
        && request.resource.data.roundId is string
        && request.resource.data.roundIndex is number
        && request.resource.data.tribeId is string
        && request.resource.data.colorId is string;

      allow read: if isAdmin();

      allow update: if
        isAdmin()
        || (
          resource.data.status == 'pending'
          && request.resource.data.status == 'confirmed'
          && resource.data.deviceId == request.resource.data.deviceId
        );
    }

    match /devices/{deviceId} {
      allow read: if isAdmin();
      allow create, update: if request.resource.data.deviceId == deviceId;
    }
  }
}

