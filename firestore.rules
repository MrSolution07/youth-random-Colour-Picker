rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Any Firebase Auth user can read responses/devices (dashboard + export).
    // No custom claims. Tighten later if you need stricter privacy.
    function isSignedIn() {
      return request.auth != null;
    }

    match /meta/{docId} {
      allow read, write: if true;
    }

    match /rounds/{roundId} {
      allow read, write: if true;
    }

    match /responses/{responseId} {
      allow create: if
        request.resource.data.status == 'pending'
        && request.resource.data.deviceId is string
        && request.resource.data.roundId is string
        && request.resource.data.roundIndex is number
        && request.resource.data.tribeId is string
        && request.resource.data.colorId is string;

      allow read: if isSignedIn();

      allow update: if
        isSignedIn()
        || (
          resource.data.status == 'pending'
          && request.resource.data.status == 'confirmed'
          && resource.data.deviceId == request.resource.data.deviceId
        );
    }

    match /devices/{deviceId} {
      allow read: if isSignedIn();
      allow create, update: if request.resource.data.deviceId == deviceId;
    }
  }
}

