rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Participants need to read/update meta + rounds to reserve quota.
    match /meta/{docId} {
      allow read, write: if isSignedIn();
    }

    match /rounds/{roundId} {
      allow read, write: if isSignedIn();
    }

    // Responses are private per participant, but admin can read all.
    match /responses/{responseId} {
      allow create: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userUid == request.auth.uid);

      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.userUid == request.auth.uid
          && request.resource.data.userUid == request.auth.uid
          && request.resource.data.status == 'confirmed');
    }

    match /devices/{deviceId} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && request.resource.data.userUid == request.auth.uid;
    }
  }
}

